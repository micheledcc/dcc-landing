# Auth
JWT_SECRET=          # Random 64-char hex: openssl rand -hex 32

# Vercel Postgres (auto-set when DB is linked in Vercel dashboard)
POSTGRES_URL=

# Google Sheets (OAuth2)
GOOGLE_CLIENT_ID=             # From credentials.json
GOOGLE_CLIENT_SECRET=         # From credentials.json
GOOGLE_REFRESH_TOKEN=         # From scripts/get-token.ts OAuth flow
GOOGLE_SHEET_ID=              # From the spreadsheet URL
GOOGLE_SHEET_RANGE=Sheet1     # Tab name
